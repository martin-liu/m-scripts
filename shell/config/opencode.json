{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "plugin": [
    "oh-my-opencode-slim@latest"
  ],
  "enabled_providers": [
    "openrouter",
    "azure",
    "azure-openai",
    "ollama"
  ],
  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "small_model": "azure/kimi-k2.6",
  "provider": {
    "ollama": {
      "models": {
        "qwen3.6:35b-a3b-q8_0": {
          "_launch": true,
          "name": "qwen3.6:35b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "azure": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure Kimi",
      "options": {
        "baseURL": "{env:AZURE_API_BASE_NANDDEVWESTUS3}/openai/deployments/kimi-k2.5",
        "headers": {
          "api-key": "{env:AZURE_API_KEY_NANDDEVWESTUS3}"
        },
        "queryParams": {
          "api-version": "{env:AZURE_API_VERSION}"
        }
      },
      "models": {
        "kimi-k2.6": {
          "name": "kimi-k2.6",
          "cost": {
            "input": 0.95,
            "output": 4
          },
          "options": {"thinking": {"type": "enabled", "budgetTokens": 16000}}
        },
        "kimi-k2.5": {
          "name": "kimi-k2.5",
          "cost": {
            "input": 0.6,
            "output": 3
          },
          "options": {"thinking": {"type": "enabled", "budgetTokens": 16000}}
        }
      }
    },
    "azure-openai": {
      "npm": "@ai-sdk/openai",
      "name": "Azure OpenAI",
      "options": {
        "baseURL": "{env:AZURE_API_BASE_NANDDEVEASTUS2}/openai/v1",
        "apiKey": "{env:AZURE_API_KEY_NANDDEVEASTUS2}"
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
              "cache_read": 0.5
            }
          }
        },
        "gpt-5.4-mini": {
          "name": "gpt-5.4-mini",
          "cost": {
            "input": 0.75,
            "output": 4.5,
            "cache_read": 0.075
          }
        },
        "gpt-5.4-pro": {
          "name": "gpt-5.4-pro",
          "cost": {
            "input": 30,
            "output": 180,
            "context_over_200k": {
              "input": 60,
              "output": 270
            }
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "model": "azure/kimi-k2.6",
  "default_agent": "orchestrator",
  "share": "manual",
  "logLevel": "DEBUG"
}
