{
  "$schema": "https://opencode.ai/config.json",
  "lsp": false,
  "plugin": [
    "oh-my-opencode-slim@latest"
  ],
  "enabled_providers": [
    "openrouter",
    "azure",
    "azure-westus3",
    "azure-openai",
    "ollama",
    "amazon-bedrock"
  ],
  "permission": {
    "external_directory": {
      "/tmp/**": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "tail_turns": 3,
    "preserve_recent_tokens": 50000,
    "reserved": 62144
  },
  "small_model": "azure/Kimi-K2.7-Code",
  "provider": {
    "ollama": {
      "models": {
        "qwen3.6:35b-a3b-q8_0": {
          "_launch": true,
          "name": "qwen3.6:35b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    },
    "azure": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure WestUS",
      "options": {
        "baseURL": "{env:AZURE_API_BASE_NANDDEVWESTUS3}/openai/deployments/Kimi-K2.7-Code",
        "headers": {
          "api-key": "{env:AZURE_API_KEY_NANDDEVWESTUS3}"
        },
        "queryParams": {
          "api-version": "{env:AZURE_API_VERSION}"
        }
      },
      "models": {
        "Kimi-K2.7-Code": {
          "name": "Kimi-K2.7-Code",
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "cost": {
            "input": 0.95,
            "output": 4
          },
          "limit": {
            "context": 262144,
            "input": 262144,
            "output": 49152
          },
          "options": {"thinking": {"type": "enabled", "budgetTokens": 16000}}
        }
      }
    },
    "azure-westus3": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Azure CentralUS",
      "options": {
        "baseURL": "{env:AZURE_API_BASE_NANDDEVWESTUS3}/openai/deployments/DeepSeek-V4-Flash",
        "headers": {
          "api-key": "{env:AZURE_API_KEY_NANDDEVWESTUS3}"
        },
        "queryParams": {
          "api-version": "{env:AZURE_API_VERSION}"
        }
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "deepseek-v4-flash",
          "cost": {
            "input": 0.19,
            "output": 0.51
          },
          "options": {"thinking": {"type": "enabled", "budgetTokens": 16000}}
        }
      }
    },

    "amazon-bedrock": {
      "options": {
        "region": "{env:AWS_REGION_BEDROCK}"
      },
      "models": {
        "us.anthropic.claude-opus-4-8-20251101-v1:0": {
          "name": "claude-opus-4.8 (cross-region)",
          "cost": {
            "input": 5,
            "output": 25,
            "cache_read": 0.5,
            "cache_write": 6.25
          },
          "limit": {
            "context": 200000,
            "output": 32000
          }
        },
        "anthropic.claude-opus-4-8": {
          "name": "claude-opus-4.8",
          "cost": {
            "input": 5,
            "output": 25,
            "cache_read": 0.5,
            "cache_write": 6.25
          },
          "limit": {
            "context": 200000,
            "output": 32000
          }
        },
        "anthropic.claude-fable-5": {
          "name": "claude-fable-5",
          "cost": {
            "input": 10,
            "output": 50,
            "cache_read": 1,
            "cache_write": 12.5
          },
          "limit": {
            "context": 200000,
            "output": 32000
          }
        }
      }
    },
    "azure-openai": {
      "npm": "@ai-sdk/openai",
      "name": "Azure OpenAI",
      "options": {
        "baseURL": "{env:AZURE_API_BASE_NANDDEVEASTUS2}/openai/v1",
        "apiKey": "{env:AZURE_API_KEY_NANDDEVEASTUS2}"
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4",
          "cost": {
            "input": 2.5,
            "output": 15,
            "cache_read": 0.25,
            "context_over_200k": {
              "input": 5,
              "output": 22.5,
              "cache_read": 0.5
            }
          }
        },
        "gpt-5.5": {
          "name": "gpt-5.5",
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
            "context_over_200k": {
              "input": 10,
              "output": 45,
              "cache_read": 1
            }
          }
        },
        "gpt-5.4-mini": {
          "name": "gpt-5.4-mini",
          "cost": {
            "input": 0.75,
            "output": 4.5,
            "cache_read": 0.075
          }
        },
        "gpt-5.4-pro": {
          "name": "gpt-5.4-pro",
          "cost": {
            "input": 30,
            "output": 180,
            "context_over_200k": {
              "input": 60,
              "output": 270
            }
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "model": "azure/Kimi-K2.7-Code",
  "default_agent": "orchestrator",
  "share": "manual",
  "logLevel": "DEBUG"
}
